# SOTYAI HAKP Network Production Environment Variables
# --------------------------------------------------

# 1. API Keys & Secrets
GEMINI_API_KEY="MY_GEMINI_API_KEY"
JWT_SECRET="your-super-secure-jwt-secret-key-change-in-prod"
API_KEY="your-sotyai-api-key"

# 2. Application URLs
APP_URL="https://sotyai.network"
CORS_ORIGINS="https://sotyai.network"

# 3. PostgreSQL Database
POSTGRES_USER="sotyai_user"
POSTGRES_PASSWORD="sotyai_password_secure"
POSTGRES_DB="sotyai_db"
POSTGRES_HOST="postgres"
POSTGRES_PORT=5432
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# 4. Redis Cache & Queue
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_PASSWORD="redis_password_secure"
REDIS_URL="redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# 5. Qdrant Vector Database
QDRANT_HOST="qdrant"
QDRANT_PORT=6333
QDRANT_API_KEY="qdrant-api-key-secure"

# 6. MinIO Object Storage
MINIO_ROOT_USER="admin"
MINIO_ROOT_PASSWORD="minio_admin_password_secure"
MINIO_ENDPOINT="minio"
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_BUCKET_NAME="sotyai-assets"

# 7. Worker & Scheduler
WORKER_CONCURRENCY=5
SCHEDULER_ENABLED=true

# 8. MCP Server
MCP_SERVER_PORT=3001

# 9. Node.js Environment
NODE_ENV="production"
PORT=3000
